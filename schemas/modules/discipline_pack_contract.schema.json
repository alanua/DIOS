{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"discipline_pack_contract.schema.json","title":"DIOS Discipline Pack Contract","description":"Bounded technical workflow contract that consumes DIOS Core records and produces evidence-backed domain results without redefining core identity, authority, approval or quantity aggregation semantics.","type":"object","additionalProperties":false,"required":["manifest_extension_ref","discipline_code","workflow_scope","measurement_method_refs","required_entity_classes","required_observation_types","allowed_output_records","human_ai_deterministic_boundary","validation_profile_refs","failure_codes","promotion_evidence_refs","prohibited_responsibilities"],"properties":{"manifest_extension_ref":{"$ref":"../dios/value_objects/identifier.schema.json"},"discipline_code":{"type":"string","pattern":"^[A-Z][A-Z0-9_.:-]{1,63}$"},"workflow_scope":{"type":"object","additionalProperties":false,"required":["problem_statement","included_operations","excluded_operations"],"properties":{"problem_statement":{"type":"string","minLength":1},"included_operations":{"type":"array","minItems":1,"items":{"type":"string","minLength":1},"uniqueItems":true},"excluded_operations":{"type":"array","minItems":1,"items":{"type":"string","minLength":1},"uniqueItems":true}}},"measurement_method_refs":{"type":"array","minItems":1,"items":{"$ref":"../dios/value_objects/identifier.schema.json"},"uniqueItems":true},"required_entity_classes":{"type":"array","minItems":1,"items":{"type":"string","minLength":1},"uniqueItems":true},"required_observation_types":{"type":"array","items":{"type":"string","minLength":1},"uniqueItems":true,"default":[]},"allowed_output_records":{"type":"array","minItems":1,"items":{"type":"string","enum":["Observation","MeasurementRecord","TechnicalValidationResult","TechnicalChangeSet","TechnicalInvalidation"]},"uniqueItems":true},"human_ai_deterministic_boundary":{"type":"array","minItems":1,"items":{"type":"object","addition