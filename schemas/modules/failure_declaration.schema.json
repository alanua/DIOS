{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"failure_declaration.schema.json","title":"DIOS Module Failure Declaration","description":"Public-safe declaration of one stable module failure condition and its downstream effect.","type":"object","additionalProperties":false,"required":["code","category","severity","retryability","blocks_downstream","evidence_required","description"],"properties":{"code":{"type":"string","pattern":"^[A-Z][A-Z0-9_]{2,127}$"},"category":{"type":"string","enum":["INPUT","REVISION","AUTHORITY","COORDINATE","UNIT","SCALE","SEMANTIC","GEOMETRY","EVIDENCE","VALIDATION","EXECUTION","PRIVACY","OUTPUT","INTEGRATION","UNKNOWN"]},"severity":{"type":"string","enum":["INFO","WARNING","ERROR","BLOCKER"]},"retryability":{"type":"string","enum":["NOT_RETRYABLE","RETRY_SAME_INPUT","RETRY_AFTER_CORRECTION","RETRY_AFTER_REVIEW"]},"blocks_downstream":{"type":"boolean"},"evidence_required":{"type":"boolean"},"description":{"type":"string","minLength":1},"recovery_action":{"type":["string","null"]},"related_validation_codes":{"type":"array","items":{"type":"string","pattern":"^[A-Z][A-Z0-9_]{2,127}$"},"uniqueItems":true,"default":[]}}}