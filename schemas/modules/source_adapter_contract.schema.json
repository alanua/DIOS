{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"source_adapter_contract.schema.json","title":"DIOS Source Adapter Contract","description":"Bounded contract for extracting source structure and observations without discipline-specific measurement or quantity authority.","type":"object","additionalProperties":false,"required":["manifest_extension_ref","supported_source_classes","supported_format_versions","revision_binding_policy","coordinate_policy","unit_policy","stage_boundaries","produced_observation_types","known_information_loss","failure_codes","validation_fixture_refs","prohibited_outputs"],"properties":{"manifest_extension_ref":{"$ref":"../dios/value_objects/identifier.schema.json"},"supported_source_classes":{"type":"array","minItems":1,"items":{"type":"string","enum":["PDF","RASTER","SCAN","VECTOR_DRAWING","BIM_EXCHANGE","MODEL_DOCUMENT","SCHEDULE","SPECIFICATION","IMAGE_REFERENCE","OTHER"]},"uniqueItems":true},"supported_format_versions":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["format_family","version_constraint"],"properties":{"format_family":{"type":"string","minLength":1},"version_constraint":{"type":"string","minLength":1},"support_level":{"type":"string","enum":["FULL","PARTIAL","METADATA_ONLY"]}}}},"revision_binding_policy":{"type":"object","additionalProperties":false,"required":["requires_registered_artifact_revision","requires_content_hash","may_assign_authority"],"properties":{"requires_registered_artifact_revision":{"const":true},"requires_content_hash":{"const":true},"may_assign_authority":{"const":false},"may_propose_authority_candidate":{"type":"boolean","default":false}}},"coordinate_policy":{"type":"object","additionalProperties":false,"required":["coordinate_modes","preserves_source_coordinates","declares_transformations"],"properties":{"coordinate_modes":{"type":"array","minItems":1,"items":{"type":"string","enum":["PAGE_SPACE","IMAGE_PIXEL_SPACE","VECTOR_MODEL_SPACE",