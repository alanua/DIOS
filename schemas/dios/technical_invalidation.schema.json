{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"technical_invalidation.schema.json","title":"Technical Invalidation","description":"Immutable stale-propagation result triggered by a technical context change. It never deletes or silently rewrites affected records.","type":"object","additionalProperties":false,"required":["technical_invalidation_id","project_context_ref","trigger_kind","trigger_refs","baseline_revision_set_id","baseline_revision_set_hash","current_revision_set_id","current_revision_set_hash","targets","propagation_edges","responsibility_trace","verification_status","privacy_class","lifecycle"],"properties":{"technical_invalidation_id":{"$ref":"value_objects/identifier.schema.json"},"project_context_ref":{"$ref":"value_objects/identifier.schema.json"},"trigger_kind":{"type":"string","enum":["SOURCE_REVISION_CHANGED","REVISION_SET_CHANGED","AUTHORITY_CHANGED","ENTITY_CONTINUITY_UNRESOLVED","VALIDATION_FAILED","METHOD_VERSION_CHANGED","MANUAL_CORRECTION","APPROVAL_CONTEXT_CHANGED"]},"trigger_refs":{"type":"array","minItems":1,"items":{"$ref":"value_objects/identifier.schema.json"},"uniqueItems":true},"baseline_revision_set_id":{"$ref":"value_objects/identifier.schema.json"},"baseline_revision_set_hash":{"$ref":"value_objects/content_hash.schema.json"},"current_revision_set_id":{"$ref":"value_objects/identifier.schema.json"},"current_revision_set_hash":{"$ref":"value_objects/content_hash.schema.json"},"change_set_ref":{"oneOf":[{"$ref":"value_objects/identifier.schema.json"},{"type":"null"}]},"targets":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["target_ref","target_type","previous_state","new_state","reason_code","propagation_path"],"properties":{"target_ref":{"$ref":"value_objects/identifier.schema.json"},"target_type":{"type":"string","enum":["SNAPSHOT","ENTITY","REPRESENTATION","OBSERVATION","MEASUREMENT_METHOD","MEASUREMENT","QUANTITY","VALIDATION_RESULT","CHANGE_SET","DERIVATIVE_ART