{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"scale_control.schema.json","title":"Scale Control","description":"Evidence-backed scale state used by a measurement record.","type":"object","additionalProperties":false,"required":["status","basis","evidence_locations"],"properties":{"status":{"type":"string","enum":["VERIFIED","NOT_REQUIRED","UNVERIFIED","CONFLICT"]},"basis":{"type":"string","enum":["EXPLICIT_CONTROL_DIMENSION","NATIVE_VECTOR_UNITS","MODEL_UNITS","DOCUMENT_DECLARATION","NONE"]},"control_dimension_observation_ref":{"oneOf":[{"$ref":"identifier.schema.json"},{"type":"null"}]},"source_distance":{"oneOf":[{"$ref":"unit_value.schema.json"},{"type":"null"}]},"real_distance":{"oneOf":[{"$ref":"unit_value.schema.json"},{"type":"null"}]},"scale_factor":{"type":["number","null"],"exclusiveMinimum":0},"evidence_locations":{"type":"array","items":{"$ref":"evidence_location.schema.json"},"default":[]},"reason":{"type":["string","null"]}},"allOf":[{"if":{"properties":{"status":{"const":"VERIFIED"}},"required":["status"]},"then":{"required":["scale_factor"],"properties":{"basis":{"not":{"const":"NONE"}},"scale_factor":{"type":"number","exclusiveMinimum":0},"evidence_locations":{"minItems":1}}}},{"if":{"properties":{"status":{"enum":["NOT_REQUIRED","UNVERIFIED","CONFLICT"]}},"required":["status"]},"then":{"required":["reason"],"properties":{"reason":{"type":"string","minLength":1}}}},{"if":{"properties":{"status":{"const":"CONFLICT"}},"required":["status"]},"then":{"properties":{"evidence_locations":{"minItems":1}}}}]}