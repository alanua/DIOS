{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"lifecycle_reference.schema.json","title":"Lifecycle Reference","description":"Shared immutable lifecycle and supersession metadata. Domain records may add stricter state enums.","type":"object","additionalProperties":false,"required":["status","created_at"],"properties":{"status":{"type":"string","enum":["DRAFT","ACTIVE","SUPERSEDED","REJECTED","VOID"]},"created_at":{"type":"string","format":"date-time"},"supersedes_ids":{"type":"array","items":{"$ref":"identifier.schema.json"},"uniqueItems":true,"default":[]},"superseded_by_id":{"oneOf":[{"$ref":"identifier.schema.json"},{"type":"null"}]},"reason":{"type":["string","null"]}},"allOf":[{"if":{"properties":{"status":{"const":"SUPERSEDED"}},"required":["status"]},"then":{"required":["superseded_by_id"],"properties":{"superseded_by_id":{"$ref":"identifier.schema.json"}}}},{"if":{"properties":{"status":{"enum":["REJECTED","VOID"]}},"required":["status"]},"then":{"required":["reason"],"properties":{"reason":{"type":"string","minLength":1}}}}]}
