{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"entity_representation.schema.json","title":"Entity Representation","description":"One exact source-bound occurrence or representation of a technical entity.","type":"object","additionalProperties":false,"required":["entity_representation_id","project_context_ref","technical_entity_id","representation_kind","representation_role","physical_identity_status","evidence_location","data_class","verification_status","privacy_class","lifecycle"],"properties":{"entity_representation_id":{"$ref":"value_objects/identifier.schema.json"},"project_context_ref":{"$ref":"value_objects/identifier.schema.json"},"technical_entity_id":{"$ref":"value_objects/identifier.schema.json"},"representation_kind":{"type":"string","enum":["PLAN","SECTION","ELEVATION","DETAIL","SCHEDULE_ROW","MODEL_ELEMENT","SYMBOL","LABEL","TABLE_ENTRY","OTHER"]},"representation_role":{"type":"string","enum":["INSTALLED_INSTANCE","LEGEND_SAMPLE","ANNOTATION","REFERENCE","OTHER"]},"physical_identity_status":{"type":"string","enum":["UNIQUE_INSTANCE","DUPLICATE_REPRESENTATION","POSSIBLE_DUPLICATE","NON_INSTANCE","UNKNOWN"]},"evidence_location":{"$ref":"value_objects/evidence_location.schema.json"},"geometry_ref":{"oneOf":[{"$ref":"value_objects/identifier.schema.json"},{"type":"null"}]},"data_class":{"$ref":"value_objects/data_class.schema.json"},"verification_status":{"$ref":"value_objects/verification_status.schema.json"},"confidence":{"$ref":"value_objects/confidence_assessment.schema.json"},"privacy_class":{"$ref":"value_objects/privacy_class.schema.json"},"lifecycle":{"$ref":"value_objects/lifecycle_reference.schema.json"},"notes":{"type":["string","null"]}},"allOf":[{"if":{"properties":{"representation_role":{"const":"LEGEND_SAMPLE"}},"required":["representation_role"]},"then":{"properties":{"physical_identity_status":{"const":"NON_INSTANCE"}}}},{"if":{"properties":{"representation_role":{"enum":["ANNOTATION","REFERENCE"]}},"required":["represent